{
  "name": "multi-runtime-monorepo",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w apps/web",
    "dev:dashboard": "npm run dev -w apps/dashboard",
    "dev:backend": "cd services/backend && python main.py",
    "dev:agent": "cd services/agent && go run cmd/server/main.go"
  }
}
